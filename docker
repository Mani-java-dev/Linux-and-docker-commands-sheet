###############################################################################
# CONTAINERS
###############################################################################

# Create and start a container interactively
docker run -it alpine

# Create and start a named container
docker run -it --name myalpine alpine

# Run container in background (detached mode)
docker run -d nginx

# Run container with a custom name
docker run -d --name mynginx nginx

# List running containers
docker ps

# List all containers (running + stopped)
docker ps -a

# Start a stopped container
docker start myalpine

# Start and attach to container
docker start -ai myalpine

# Stop a running container
docker stop myalpine

# Restart a container
docker restart myalpine

# Pause a container
docker pause myalpine

# Unpause a container
docker unpause myalpine

# Kill a container immediately
docker kill myalpine

# Remove a stopped container
docker rm myalpine

# Force remove a running container
docker rm -f myalpine

# Rename a container
docker rename oldname newname


