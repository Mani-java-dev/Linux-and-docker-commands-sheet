# 1. Download the Alpine Linux image from Docker Hub
docker pull alpine

# 2. Verify that the image was downloaded
docker images

# 3. Create and start a container named "myalpine"
#    -i = interactive mode
#    -t = terminal
docker run -it --name myalpine alpine

# 4. Inside the container, check the OS information
cat /etc/os-release

# 5. Exit the container
exit

# 6. View all containers (running and stopped)
docker ps -a

# 7. Start the stopped container and attach to its terminal
docker start -ai myalpine

# 8. Exit again when finished
exit

# 9. Run a container in the background
#    This keeps the container alive by running an infinite sleep loop
docker run -dit --name alpine-bg alpine sh -c "while true; do sleep 3600; done"

# 10. Check running containers
docker ps

# 11. Open a shell inside the running background container
docker exec -it alpine-bg sh

# 12. Exit the shell (container keeps running)
exit

# 13. Stop the background container
docker stop alpine-bg

# 14. Start the background container again
docker start alpine-bg

# 15. View detailed information about the container
docker inspect alpine-bg

# 16. Remove the container (must be stopped first)
docker rm alpine-bg

# 17. Remove the image
docker rmi alpine


